# Minimal Doxyfile to feed Breathe with XML for C++ API reference.
# Run from the docs/ directory: `doxygen Doxyfile`.

PROJECT_NAME           = "Tamagoyaki"
PROJECT_NUMBER         = "0.1.0"
PROJECT_BRIEF          = "MLIR-based equality saturation framework"

OUTPUT_DIRECTORY       = doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English

# We only consume XML in Sphinx via Breathe.
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = YES

EXTENSION_MAPPING      = inc=C++

# Source layout.
INPUT                  = ../include \
                         ../src \
                         ../herbie_mlir/include \
                         ../herbie_mlir/src \
                         ../herbie_mlir/tools \
                         ../rover-mlir/include \
                         ../rover-mlir/src \
                         ../rover-mlir/tools \
                         ../cranelift-mlir/include \
                         ../cranelift-mlir/src \
                         ../cranelift-mlir/tools \
                         @TAMAGOYAKI_BUILD_DIR@/include \
                         @TAMAGOYAKI_BUILD_DIR@/herbie_mlir/include \
                         @TAMAGOYAKI_BUILD_DIR@/rover-mlir/include \
                         @TAMAGOYAKI_BUILD_DIR@/cranelift-mlir/include
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.hxx *.cpp *.cc *.cxx *.c *.inc
INCLUDE_FILE_PATTERNS  = *.h *.hpp *.hxx *.inc
# Sources `#include "<Name>Passes.h.inc"` without a subdirectory prefix.
# Herbie's tablegen output sits directly under build/herbie_mlir/include,
# but rover and cranelift nest theirs one level deeper, so the dialect
# subdirectories must also be on INCLUDE_PATH (which is not recursive).
INCLUDE_PATH           = @TAMAGOYAKI_BUILD_DIR@/include \
                         @TAMAGOYAKI_BUILD_DIR@/herbie_mlir/include \
                         @TAMAGOYAKI_BUILD_DIR@/cranelift-mlir/include \
                         @TAMAGOYAKI_BUILD_DIR@/cranelift-mlir/include/Cranelift \
                         @TAMAGOYAKI_BUILD_DIR@/rover-mlir/include \
                         @TAMAGOYAKI_BUILD_DIR@/rover-mlir/include/Rover
EXCLUDE_PATTERNS       = */vendor/* */test/* */tests/*

# Parsing.
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
INHERIT_DOCS           = YES
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES

JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = NO
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES

# We don't need full call graphs in XML.
HAVE_DOT               = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# Predefine TableGen guard macros so that Doxygen sees the class declarations
# inside `#ifdef GET_OP_CLASSES`, `#ifdef GET_TYPEDEF_CLASSES`, etc., in the
# generated *.h.inc files. Without this, out-of-line definitions of methods
# such as Op::verify() in *.cpp files cannot be matched to a declaration and
# Doxygen emits "documented symbol ... was not declared or defined" warnings.
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = GET_OP_CLASSES \
                         GET_OP_LIST \
                         GET_TYPEDEF_CLASSES \
                         GET_TYPEDEF_LIST \
                         GET_ATTRDEF_CLASSES \
                         GET_ATTRDEF_LIST \
                         GEN_PASS_DECL \
                         GEN_PASS_REGISTRATION

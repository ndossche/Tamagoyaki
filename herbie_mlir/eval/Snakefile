import os
import glob

herbie_mlir_opt_path = "../../build/bin/herbie-mlir-opt"
herbie_racket_prefix = "../../build/herbie_mlir/racket-pkgs"

# Get all benchmark names from fpcore files
benchmark_names = [
    os.path.splitext(os.path.basename(f))[0]
    for f in glob.glob("fpcore/*.fpcore")
]

OUT_DIR = "out"
RULES_DIR = f"{OUT_DIR}/rules"
MLIR_DIR = f"{OUT_DIR}/mlir"
OPTIMIZED_DIR = f"{OUT_DIR}/optimized"
OPTIMIZED_FPCORE_DIR = f"{OUT_DIR}/optimized_fpcore"
FPCORE_MERGED_DIR = f"{OUT_DIR}/fpcore_merged"
HERBIE_EVAL_DIR = f"{OUT_DIR}/herbie_eval"
BENCHMARKS_DIR = f"{OUT_DIR}/benchmarks"
PLOTS_DIR = f"{OUT_DIR}/plots"
SATURATION_TIMING_DIR = f"{OUT_DIR}/saturation_timing"

rule all:
    input:
        f"{PLOTS_DIR}/accuracy_comparison.pdf",
        f"{PLOTS_DIR}/accuracy_comparison_compact.pdf",
        f"{PLOTS_DIR}/timing_comparison.pdf",
        f"{PLOTS_DIR}/matcher_speedup.pdf",

# ============ Rules Processing Pipeline ============

rule convert_rules_to_pdl:
    output:
        f"{RULES_DIR}/rules_pdl.mlir"
    shell:
        "uv run herbie-pdl ../rules.rkt > {output}"

rule convert_pdl_to_pdl_interp:
    input:
        f"{RULES_DIR}/rules_pdl.mlir"
    output:
        f"{RULES_DIR}/rules_pdl_interp.mlir"
    shell:
        "uv run xdsl-opt -p 'convert-pdl-to-pdl-interp{{optimize_for_eqsat=true}}' {input} -o {output}"

rule convert_pdl_to_pdl_interp_individual:
    input:
        f"{RULES_DIR}/rules_pdl.mlir"
    output:
        f"{RULES_DIR}/rules_pdl_interp_individual.mlir"
    shell:
        "uv run xdsl-opt -p 'convert-pdl-to-pdl-interp{{optimize_for_eqsat=true convert-individually=true}}' {input} -o {output}"

# ============ Benchmark Processing Pipeline ============

rule fpcore_to_mlir:
    input:
        "fpcore/{benchmark}.fpcore"
    output:
        f"{MLIR_DIR}/{{benchmark}}.mlir"
    shell:
        "uv run fpcore-mlir {input} > {output}"

rule optimize:
    input:
        mlir = f"{MLIR_DIR}/{{benchmark}}.mlir",
        pdl_interp = f"{RULES_DIR}/rules_pdl_interp.mlir"
    output:
        f"{OPTIMIZED_DIR}/{{benchmark}}.mlir"
    benchmark:
        f"{BENCHMARKS_DIR}/{{benchmark}}.tsv"
    shell:
        '{herbie_mlir_opt_path} -herbie-optimize="max-saturation-iters=20 max-nodes=4000 patterns-file={input.pdl_interp}" --remove-dead-values {input.mlir} > {output}'

# ============ Saturation Timing Pipeline ============

rule saturation_timing_joint:
    input:
        mlir = f"{MLIR_DIR}/{{benchmark}}.mlir",
        pdl_interp = f"{RULES_DIR}/rules_pdl_interp.mlir"
    output:
        f"{SATURATION_TIMING_DIR}/{{benchmark}}_joint.json"
    shell:
        'mkdir -p {SATURATION_TIMING_DIR} && {herbie_mlir_opt_path} -equivalence-insert-graph -ematch-saturate="patterns-file={input.pdl_interp} max-iters=20 max-nodes=4000 eager-rewrite=false" {input.mlir} -tamagoyaki-timing -tamagoyaki-timing-output=json 2> {output} > /dev/null'

rule saturation_timing_individual:
    input:
        mlir = f"{MLIR_DIR}/{{benchmark}}.mlir",
        pdl_interp = f"{RULES_DIR}/rules_pdl_interp_individual.mlir"
    output:
        f"{SATURATION_TIMING_DIR}/{{benchmark}}_individual.json"
    shell:
        'mkdir -p {SATURATION_TIMING_DIR} && {herbie_mlir_opt_path} -equivalence-insert-graph -ematch-saturate="patterns-file={input.pdl_interp} max-iters=20 max-nodes=4000 eager-rewrite=false" {input.mlir} -tamagoyaki-timing -tamagoyaki-timing-output=json 2> {output} > /dev/null'

rule optimized_mlir_to_fpcore:
    input:
        f"{OPTIMIZED_DIR}/{{benchmark}}.mlir"
    output:
        f"{OPTIMIZED_FPCORE_DIR}/{{benchmark}}.fpcore"
    shell:
        "uv run mlir-fpcore {input} > {output}"

# ============ FPCore Merging Pipeline ============

rule insert_fpcore_alternatives:
    input:
        original = "fpcore/{benchmark}.fpcore",
        optimized = f"{OPTIMIZED_FPCORE_DIR}/{{benchmark}}.fpcore"
    output:
        f"{FPCORE_MERGED_DIR}/{{benchmark}}.fpcore"
    shell:
        "uv run insert-fpcore-alternative {input.original} {input.optimized} > {output}"

rule concatenate_merged_fpcores:
    input:
        expand(f"{FPCORE_MERGED_DIR}/{{benchmark}}.fpcore", benchmark=benchmark_names)
    output:
        f"{OUT_DIR}/herbie_input.fpcore"
    shell:
        "cat {input} > {output}"

# ============ Herbie Evaluation Pipeline ============

rule run_herbie_report:
    input:
        f"{OUT_DIR}/herbie_input.fpcore"
    output:
        directory(f"{HERBIE_EVAL_DIR}/herbie_report")
    shell:
        'PLTADDONDIR={herbie_racket_prefix} racket -l herbie report --disable setup:preprocess --disable reduce:regimes --disable generate:taylor --disable generate:proofs  --platform math --num-iters 1 --seed 42 {input} {output}'

# ============ Evaluation Export Pipeline ============

rule extract_evaluation_csv:
    input:
        report = f"{HERBIE_EVAL_DIR}/herbie_report",
        benchmarks = expand(f"{BENCHMARKS_DIR}/{{benchmark}}.tsv", benchmark=benchmark_names),
        timing_joint = expand(f"{SATURATION_TIMING_DIR}/{{benchmark}}_joint.json", benchmark=benchmark_names),
        timing_individual = expand(f"{SATURATION_TIMING_DIR}/{{benchmark}}_individual.json", benchmark=benchmark_names),
    output:
        f"{OUT_DIR}/evaluation.csv"
    shell:
        "uv run extract-accuracies {input.report}/results.json {BENCHMARKS_DIR} {SATURATION_TIMING_DIR} > {output}"

# ============ Plotting Pipeline ============

rule generate_accuracy_plot:
    input:
        f"{OUT_DIR}/evaluation.csv"
    output:
        f"{PLOTS_DIR}/accuracy_comparison.pdf"
    shell:
        "uv run plot-accuracies {input} -o {output}"

rule generate_accuracy_plot_compact:
    input:
        f"{OUT_DIR}/evaluation.csv"
    output:
        f"{PLOTS_DIR}/accuracy_comparison_compact.pdf"
    shell:
        "uv run plot-accuracies {input} -o {output} --compact"

rule generate_matcher_speedup_plot:
    input:
        f"{OUT_DIR}/evaluation.csv"
    output:
        f"{PLOTS_DIR}/matcher_speedup.pdf"
    shell:
        "uv run plot-matcher-speedup {input} -o {output}"

rule generate_timing_plot:
    input:
        f"{OUT_DIR}/evaluation.csv"
    output:
        f"{PLOTS_DIR}/timing_comparison.pdf"
    shell:
        "uv run plot-timing {input} -o {output}"

# ============ Utility Rules ============

rule clean:
    shell:
        f"rm -rf {OUT_DIR}"
